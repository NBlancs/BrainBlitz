generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  name         String
  age          Int
  ageGroup     AgeGroup
  totalPoints  Int      @default(0)
  badge        Badge    @default(BRONZE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  scores       Score[]

  @@index([username])
}

model Category {
  id        String     @id @default(uuid())
  name      String     @unique
  icon      String
  questions Question[]
  scores    Score[]

  @@index([name])
}

model Question {
  id         String     @id @default(uuid())
  text       String
  difficulty Difficulty
  country    Country
  categoryId String
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  answers    Answer[]

  @@index([categoryId, country, difficulty])
}

model Answer {
  id         String   @id @default(uuid())
  text       String
  isCorrect  Boolean
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model Score {
  id         String   @id @default(uuid())
  userId     String
  categoryId String
  points     Int
  correctAnswers Int
  totalQuestions Int
  speedBonus Int      @default(0)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, points(sort: Desc)])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

enum AgeGroup {
  KIDS
  TEEN
  ADULT
}

enum Badge {
  BRONZE
  SILVER
  GOLD
  SCHOLAR
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Country {
  PHILIPPINES
  UNITED_STATES
  GREAT_BRITAIN
  CHINA
  JAPAN
  SOUTH_KOREA
}
